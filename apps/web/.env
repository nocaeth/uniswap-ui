# --- Gnosis swap routing (UniversalRouter) ---
# Real UniversalRouter, deployed to Gnosis MAINNET (chain 100) at block 46896855,
# tx 0x4d0a5201f843ba9ba2ed84614ca55c8b0223d30428f006aa4fd600600f6eb00d.
# For local-fork dev, restart anvil to fork from latest (`anvil --fork-url $RPC_GNOSIS`)
# so this address is present on the fork. Use 127.0.0.1 (not localhost) to match dev CSP.
REACT_APP_GNOSIS_RPC_URL="http://127.0.0.1:8545"
REACT_APP_GNOSIS_UNIVERSAL_ROUTER_ADDRESS="0xa437dC83CDDa879167a40114706F6EB0558E6d7c"

# --- Gnosis analytics adapter (Explore page data: ExploreStats ConnectRPC) ---
# Points the Data API v2 transport at the local adapter (gnosis/adapter on :8081),
# which serves Gnosis V3 token/pool/protocol stats + token rankings from a SQLite
# historical index (HyperSync events + RPC state).
API_BASE_URL_V2_OVERRIDE="http://127.0.0.1:8081"

# Token/pool detail pages + transactions read from the adapter's GraphQL endpoint
# (graphql-yoga mounted at /v1/graphql), which resolves Uniswap's web GraphQL
# operations from the same SQLite index.
GRAPHQL_URL_OVERRIDE="http://127.0.0.1:8081/v1/graphql"
