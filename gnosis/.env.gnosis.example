# ---------------------------------------------------------------------------
# Gnosis-only deployment environment
# Copy the relevant values into apps/web/.env (or your runtime env) for the web
# app, and into gnosis/docker-compose .env for the infra services.
# ---------------------------------------------------------------------------

# --- Web app (apps/web) ---------------------------------------------------

# WalletConnect v2 project id (required for the wallet modal). Get one at
# https://cloud.walletconnect.com/
REACT_APP_WALLET_CONNECT_PROJECT_ID=

# Gnosis RPC. The chain-info file ships sensible public defaults
# (rpc.gnosischain.com / gnosis.drpc.org). For production self-hosting, point
# these at your own node or a paid endpoint by editing
# packages/uniswap/src/features/chains/evm/info/gnosis.ts, or front them with
# the analytics adapter below.

# Repoint the data/analytics layer away from Uniswap's gateway (which does NOT
# serve Gnosis) to our self-hosted Envio analytics adapter.
API_BASE_URL_V2_OVERRIDE=https://analytics.YOURDOMAIN.tld
GRAPHQL_URL_OVERRIDE=https://analytics.YOURDOMAIN.tld/v1/graphql

# Swap routing is computed client-side for Gnosis (QuoterV2), so the Trading API
# is not used. If you later self-host a routing-api, point it here.
# TRADING_API_URL_OVERRIDE=

# --- Contract deployment (gnosis/contracts) -------------------------------

# RPC + deployer key used by the forge deploy scripts.
GNOSIS_RPC_URL=https://rpc.gnosischain.com
DEPLOYER_PRIVATE_KEY=
GNOSISSCAN_API_KEY=

# Filled in AFTER deployment (see gnosis/contracts/README.md). The UniversalRouter
# address must also be wired into the universal-router-sdk resolution for chain 100
# (see gnosis/contracts/README.md "Wiring addresses back into the app").
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3
UNIVERSAL_ROUTER_ADDRESS=

# --- Envio indexer (gnosis/envio) -----------------------------------------

# HyperSync / RPC source for the indexer (Envio provides a Gnosis HyperSync URL).
ENVIO_GNOSIS_RPC_URL=https://rpc.gnosischain.com
# Price feed used to denominate TVL/volume in USD (CoinGecko or your own).
PRICE_FEED_API_KEY=
