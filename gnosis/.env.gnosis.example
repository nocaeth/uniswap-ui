# ---------------------------------------------------------------------------
# Gnosis-only deployment environment
# Copy to gnosis/.env for `docker compose -f gnosis/docker-compose.yml up`.
# (For local `nx start web` dev, the web values live in apps/web/.env instead.)
# ---------------------------------------------------------------------------

# --- Web app (baked into the bundle at build time via compose build args) ---

# WalletConnect v2 project id (required for the wallet modal). Get one at
# https://cloud.walletconnect.com/
REACT_APP_WALLET_CONNECT_PROJECT_ID=

# Gnosis RPC the browser uses for reads + swaps. Defaults in the chain-info file
# are public endpoints; override here to point at your own/paid node.
REACT_APP_GNOSIS_RPC_URL=https://rpc.gnosischain.com

# UniversalRouter address for chain 100 (fill in after deploying it, below).
REACT_APP_GNOSIS_UNIVERSAL_ROUTER_ADDRESS=

# SdaiZapRouter address for chain 100. Enables WXDAI/xDAI <-> deep sDAI-cluster
# zap routing when set.
REACT_APP_GNOSIS_SDAI_ZAP_ADDRESS=

# GnosisAggregationRouter + Curve Router NG addresses. When both are set, exact-input
# quotes can split across V3 and curated Curve x3pool routes, with the USDC transmuter
# available inside the same atomic transaction.
REACT_APP_GNOSIS_AGGREGATION_ROUTER_ADDRESS=
REACT_APP_GNOSIS_CURVE_ROUTER_ADDRESS=

# Split-fill routing is enabled by default. Set to false to force single-route swaps.
REACT_APP_GNOSIS_SPLIT_ENABLED=true

# Repoint the data/analytics layer away from Uniswap's gateway (which does NOT serve
# Gnosis) to the self-hosted analytics adapter. Served same-origin under /api (the web
# image's nginx proxies /api -> the adapter container), so use your web host + /api.
API_BASE_URL_V2_OVERRIDE=https://swap.gno.now/api
GRAPHQL_URL_OVERRIDE=https://swap.gno.now/api/v1/graphql

# Swap routing is computed client-side for Gnosis (QuoterV2), so the Trading API
# is not used. If you later self-host a routing-api, point it here.
# TRADING_API_URL_OVERRIDE=

# --- Analytics indexer (gnosis/adapter backfill -> SQLite) ----------------

# Envio HyperSync auth token used by the backfill (free tier rate-limits without
# one). Get one at https://envio.dev. Already exported in the dev shell's .zshrc.
ENVIO_API_TOKEN=
# Gnosis RPC the backfill reads from (separate from the browser RPC above).
RPC_GNOSIS=https://rpc.gnosischain.com
# Indexing windows: INDEX_DAYS drives the rollups/charts, TX_DAYS the tx feed.
INDEX_DAYS=30
TX_DAYS=7

# Incremental syncer. The syncer tails HyperSync after the one-shot backfill and
# should replace any frequent external cron that reruns the full backfill.
SYNC_INTERVAL_MS=60000
SYNC_FINALITY_BLOCKS=24
SYNC_SNAPSHOT_INTERVAL_MS=300000
SYNC_BOOTSTRAP_BACKFILL=true

# --- Contract deployment (gnosis/contracts) -------------------------------

# RPC + deployer key used by the forge deploy scripts.
GNOSIS_RPC_URL=https://rpc.gnosischain.com
DEPLOYER_PRIVATE_KEY=
# Unified Etherscan V2 API key (https://etherscan.io/myapikey) for `forge verify` with
# `--verifier etherscan --chain 100`. One key works for all chains; the per-chain
# gnosisscan.io V1 endpoint is deprecated.
ETHERSCAN_API_KEY=

# Filled in AFTER deployment (see gnosis/contracts/README.md). The UniversalRouter
# address must also be wired into the universal-router-sdk resolution for chain 100
# (see gnosis/contracts/README.md "Wiring addresses back into the app").
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3
UNIVERSAL_ROUTER_ADDRESS=
SDAI_ZAP_ADDRESS=
AGGREGATION_ROUTER_ADDRESS=
EXPECTED_GNOSIS_CURVE_ROUTER_ADDRESS=
EXPECTED_GNOSIS_CURVE_ROUTER_CODEHASH=
EXPECTED_GNOSIS_AGGREGATION_ROUTER_ADDRESS=
EXPECTED_GNOSIS_AGGREGATION_ROUTER_CODEHASH=
